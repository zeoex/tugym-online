generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id           Int      @id @default(autoincrement())
  nombre       String
  email        String   @unique
  passwordHash String   @map("password_hash")
  rol          String   @default("ADMIN")
  activo       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("usuarios")
}

model Socio {
  id            Int      @id @default(autoincrement())
  nombre        String
  apellido      String
  email         String?  @unique
  telefono      String?
  dni           String?  @unique
  foto          String?
  sexo          String     @default("OTROS")
  fechaNac      DateTime?  @map("fecha_nac")
  fechaAlta     DateTime   @default(now()) @map("fecha_alta")
  estado        String     @default("ACTIVO")
  observaciones  String?
  rutinaAsignada String?  @map("rutina_asignada")
  tipoRutina     String?  @map("tipo_rutina")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  rutinaId       Int?     @map("rutina_asignada_id")
  pinHash        String?  @map("pin_hash")

  pagos          Pago[]
  notificaciones Notificacion[]
  asistencias    Asistencia[]
  rutinaAsignadaRef Rutina? @relation("RutinaAsignada", fields: [rutinaId], references: [id], onDelete: SetNull)
  rutinasPersonales Rutina[] @relation("RutinasPersonales")

  @@index([apellido, nombre])
  @@index([estado])
  @@map("socios")
}

model Ejercicio {
  id        Int      @id @default(autoincrement())
  nombre    String
  musculo   String?
  mediaKey  String?  @map("media_key")
  categoria String   @default("CUERPO")
  activo    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  items     RutinaItem[]

  @@index([nombre])
  @@map("ejercicios")
}

model Rutina {
  id        Int      @id @default(autoincrement())
  nombre    String
  tipo      String   @default("GENERAL")
  socioId   Int?     @map("socio_id")
  activo    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  socio     Socio?   @relation("RutinasPersonales", fields: [socioId], references: [id], onDelete: Cascade)
  asignadaA Socio[]  @relation("RutinaAsignada")
  items     RutinaItem[]

  @@index([socioId])
  @@index([tipo])
  @@map("rutinas")
}

model RutinaItem {
  id          Int    @id @default(autoincrement())
  rutinaId    Int    @map("rutina_id")
  ejercicioId Int    @map("ejercicio_id")
  orden       Int    @default(0)
  series      Int    @default(3)
  reps        String @default("10-12")
  descanso    String @default("60 seg")

  rutina      Rutina    @relation(fields: [rutinaId], references: [id], onDelete: Cascade)
  ejercicio   Ejercicio @relation(fields: [ejercicioId], references: [id])

  @@index([rutinaId])
  @@map("rutina_items")
}

model Plan {
  id           Int      @id @default(autoincrement())
  nombre       String
  tipo         String
  duracionDias Int      @map("duracion_dias")
  precio       Float
  descripcion  String?
  activo       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  pagos        Pago[]

  @@map("planes")
}

model Pago {
  id               Int      @id @default(autoincrement())
  socioId          Int      @map("socio_id")
  planId           Int      @map("plan_id")
  monto            Float
  recargo          Float    @default(0)
  fechaPago        DateTime @default(now()) @map("fecha_pago")
  fechaVencimiento DateTime @map("fecha_vencimiento")
  estado           String   @default("ACTIVO")
  metodoPago       String   @default("EFECTIVO") @map("metodo_pago")
  observaciones    String?
  createdAt        DateTime @default(now()) @map("created_at")

  socio            Socio    @relation(fields: [socioId], references: [id])
  plan             Plan     @relation(fields: [planId], references: [id])

  @@index([socioId])
  @@index([fechaVencimiento])
  @@index([estado])
  @@map("pagos")
}

model RutinaDia {
  id         Int      @id @default(autoincrement())
  fecha      DateTime
  tipo       String
  nombre     String   @default("")
  ejercicios String
  editada    Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@unique([fecha, tipo])
  @@map("rutinas_dia")
}

model CajaDia {
  id            Int      @id @default(autoincrement())
  fecha         DateTime @unique
  montoApertura Float    @default(0) @map("monto_apertura")
  montoCierre   Float?   @map("monto_cierre")
  estado        String   @default("ABIERTA")
  observaciones String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("caja_dia")
}

model Anuncio {
  id        Int       @id @default(autoincrement())
  titulo    String
  contenido String
  activo    Boolean   @default(true)
  fechaFin  DateTime? @map("fecha_fin")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@map("anuncios")
}

model Configuracion {
  id               Int      @id @default(autoincrement())
  nombreGym        String   @default("TuGymOnLine") @map("nombre_gym")
  telefono         String?
  direccion        String?
  instagram        String?
  horarios         String?
  latitud          Float?
  longitud         Float?
  radioCheckin     Int      @default(150) @map("radio_checkin_m")
  checkinVentanaHs Int      @default(3) @map("checkin_ventana_hs")
  diaPagoDesde     Int      @default(1) @map("dia_pago_desde")
  diaPagoHasta     Int      @default(10) @map("dia_pago_hasta")
  recargoActivo    Boolean  @default(false) @map("recargo_activo")
  recargoTipo      String   @default("PORCENTAJE") @map("recargo_tipo")
  recargoValor     Float    @default(10) @map("recargo_valor")
  diasAviso        Int      @default(3) @map("dias_aviso_vencimiento")
  msgMoroso        String?  @map("msg_moroso")
  msgRecuperacion  String?  @map("msg_recuperacion")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("configuracion")
}

model Asistencia {
  id           Int      @id @default(autoincrement())
  socioId      Int      @map("socio_id")
  fecha        DateTime @default(now())
  metodo       String   @default("GEO")
  distanciaM   Int?     @map("distancia_m")
  cuotaVencida Boolean  @default(false) @map("cuota_vencida")
  deviceId     String?  @map("device_id")

  socio        Socio    @relation(fields: [socioId], references: [id], onDelete: Cascade)

  @@index([socioId])
  @@index([fecha])
  @@index([deviceId])
  @@map("asistencias")
}

model Notificacion {
  id         Int      @id @default(autoincrement())
  socioId    Int      @map("socio_id")
  tipo       String
  mensaje    String
  enviado    Boolean  @default(false)
  fechaEnvio DateTime? @map("fecha_envio")
  createdAt  DateTime  @default(now()) @map("created_at")

  socio      Socio    @relation(fields: [socioId], references: [id])

  @@index([socioId])
  @@index([enviado])
  @@map("notificaciones")
}
