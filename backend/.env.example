# Base de datos PostgreSQL
# En Railway la inyecta el servicio Postgres como ${{Postgres.DATABASE_URL}}
DATABASE_URL="postgresql://usuario:password@localhost:5432/gymapp"

# JWT
JWT_SECRET="cambia_esto_por_un_secreto_seguro_largo"
JWT_EXPIRES_IN="8h"

# Puerto del servidor (Railway lo inyecta en producción)
PORT=4000

# Carpeta de fotos de socios. En Railway apunta al volumen montado (/app/uploads).
# Vacío en local: usa backend/uploads
UPLOADS_DIR=

# Email (opcional, para notificaciones de vencimiento)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu@email.com
SMTP_PASS=tu_app_password
EMAIL_FROM=GymApp <tu@email.com>

# URL del frontend para CORS
# En Railway con servicio único: la URL pública del propio servicio
FRONTEND_URL=http://localhost:5173
