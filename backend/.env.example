# Base de datos PostgreSQL (obtener desde Supabase: Settings > Database > Connection string > URI)
# Formato: postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
DATABASE_URL="postgresql://usuario:password@localhost:5432/gymapp"

# JWT
JWT_SECRET="cambia_esto_por_un_secreto_seguro_largo"
JWT_EXPIRES_IN="8h"

# Puerto del servidor
PORT=4000

# Email (opcional, para notificaciones de vencimiento)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu@email.com
SMTP_PASS=tu_app_password
EMAIL_FROM=GymApp <tu@email.com>

# URL del frontend para CORS (en producción: URL de Vercel)
FRONTEND_URL=http://localhost:5173
