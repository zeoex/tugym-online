backend/src/uploads/*
!backend/src/uploads/.gitkeep

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo

# Claude Code internal files
.claude/

# Prisma generated client (regenerated on install)
backend/node_modules/
frontend/node_modules/
